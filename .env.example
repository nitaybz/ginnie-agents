# ginnie-agents — Environment Variables
# Copy to .env and fill in values. Per-agent Slack tokens belong in
# agents/<name>/credentials.json (gitignored), NOT here.

# ─── Claude Code Auth (REQUIRED) ────────────────────────────
# Long-lived (~1 year) OAuth token from `claude setup-token`.
# Strongly recommended over mounting host credentials — those expire after 8h
# and cannot be refreshed inside the read-only container.
# To generate: run `claude setup-token` on the host and copy the printed token.
CLAUDE_CODE_OAUTH_TOKEN=

# ─── Container Timezone ─────────────────────────────────────
# Defaults to UTC if unset. Examples: UTC, America/New_York, Europe/London,
# Asia/Tokyo, Asia/Jerusalem. Used both by the listener's scheduler and by
# the agent containers themselves. Cron expressions in schedules.json are
# interpreted in this timezone.
TZ=UTC

# ─── Slack workspace ────────────────────────────────────────
# Your Slack workspace URL (e.g. acme.slack.com). Used by the create-agent
# skill to build install URLs for new Slack apps.
SLACK_WORKSPACE_URL=

# ─── Slack App Configuration Tokens (optional, programmatic path) ───
# If set, the create-agent skill will auto-generate Slack apps via the
# manifest API instead of walking you through ~20 clicks per agent.
# Generate at https://api.slack.com/apps (bottom of the page → "Your App
# Configuration Tokens" → Generate Token). Requires admin/owner of the
# workspace. The Access Token expires every 12h; the framework rotates it
# automatically using the refresh token. Leave both blank to use the manual
# (clicked-through) flow instead.
SLACK_CONFIG_TOKEN=
SLACK_CONFIG_REFRESH_TOKEN=

# ─── Watcher (optional, recommended) ────────────────────────
# The Watcher is a long-running daemon that monitors framework health
# (token expiry, framework updates, PM2 listener state, disk, memory caps)
# and DMs you on Slack only when something needs attention. It posts
# interactive buttons for actionable alerts (Update now / Restart / Ack).
#
# Setup: ask Claude to run the `setup-watcher` skill — it creates the Slack
# app via manifest, walks you through the 2-click install, and writes these
# values back into .env automatically.
WATCHER_BOT_TOKEN=
WATCHER_APP_TOKEN=
OPERATOR_SLACK_ID=
# How often the Watcher runs its checks (minutes). Default 60. Override
# only if you have a strong reason — checks are cheap, but Slack DMs aren't
# wallpaper.
WATCHER_CHECK_INTERVAL_MIN=60

# ─── Slack (optional fallback only) ─────────────────────────
# Each agent has its own Slack app — tokens belong in
# agents/<name>/credentials.json. These root-level tokens are only used as a
# fallback for the single-agent case.
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
